<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SabakaLang.Studio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d"
        x:Class="SabakaLang.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SabakaLang Studio"
        Width="1200" Height="740"
        MinWidth="600" MinHeight="400"
        Background="#1E1F22">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <Border Grid.Row="0" Classes="Toolbar" Height="40">
            <DockPanel Margin="8,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Classes="RunBtn" Name="BtnRun" ToolTip.Tip="Run (F5)" HorizontalAlignment="Right">▶  Run</Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Button Name="BtnSave" ToolTip.Tip="Save (Ctrl+S)" HorizontalAlignment="Right">💾 Save</Button>
                    <Button Name="BtnOpen" ToolTip.Tip="Open" HorizontalAlignment="Right">📂 Open</Button>
                    <Button Name="BtnBytecode" ToolTip.Tip="View bytecode" HorizontalAlignment="Right">View bytecode</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <avaloniaEdit:TextEditor
            Grid.Row="2"
            Name="Editor"
            ShowLineNumbers="True"
            FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
            FontSize="14"
            Background="#1E1F22"
            Foreground="#BCBEC4"
            LineNumbersForeground="#555759"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Padding="0,4">
            <avaloniaEdit:TextEditor.Text>
print("Hello world!");
            </avaloniaEdit:TextEditor.Text>
        </avaloniaEdit:TextEditor>

        <Border Grid.Row="3" Classes="ProblemsBar">
            <ContentControl Name="DiagnosticsPanelHost"/>
        </Border>

        <Border Grid.Row="4" Classes="StatusBar">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Classes="StatusText" Name="StatusErrors"   Text="⛔ 0"/>
                    <Border Width="1" Height="14" Background="#2860CC" Margin="0,4"/>
                    <TextBlock Classes="StatusText" Name="StatusWarnings" Text="⚠ 0"/>
                    <Border Width="1" Height="14" Background="#2860CC" Margin="0,4"/>
                    <TextBlock Classes="StatusText" Name="StatusPosition" Text="Ln 1, Col 1"/>
                </StackPanel>

                <TextBlock Classes="StatusText" Name="StatusMessage"
                           HorizontalAlignment="Left" Text="Ready"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
