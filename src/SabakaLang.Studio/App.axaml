<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SabakaLang.Studio.App"
             xmlns:local="using:SabakaLang.Studio"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <FontFamily x:Key="JbFont">avares://SabakaLang.Studio/Assets/Fonts#JetBrains Mono</FontFamily>
    </Application.Resources>
    
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://SabakaLang.Studio/Theme.axaml" />
    </Application.Styles>
</Application>