<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SabakaLang.Debugger.MainWindow"
        Title="SabakaLang Debugger"
        Width="900" Height="600">
    
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <Button Content="Debug" Name="DebugButton"
                    Background="MediumSeaGreen" Foreground="White"/>
              <Button Content="Step (F10)" Name="StepButton"/>
            <Separator Opacity="0"/>
            <TextBlock Name="PathBlock" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <TextBox DockPanel.Dock="Bottom" 
                 Name="ConsoleOutput"
                 Height="150" 
                 IsReadOnly="True" 
                 AcceptsReturn="True" 
                 FontFamily="Cascadia Code,Consolas,Monospace"
                 Watermark="Console Output..."
                 Margin="0,10,0,0"/>

        <Grid>
            <TextBox Name="CodeArea" 
                     IsReadOnly="True" 
                     AcceptsReturn="True"
                     FontFamily="Cascadia Code,Consolas,Monospace"
                     HorizontalAlignment="Stretch" 
                     VerticalAlignment="Stretch"
                     Watermark="Instructions will be here..."/>
        </Grid>
    </DockPanel>
</Window>
